PORT=8787
HOST=0.0.0.0
CORS_ORIGIN=*
BACKEND_MODE=dummy
SIM_SEED=42
SIM_TICK_MS=2000
SIM_ERROR_RATE=0

# LLM Provider: openai, anthropic, gemini, zhipu, minimax, deepseek, groq, together, or any OpenAI-compatible provider
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# Only Anthropic uses a different format. All others are OpenAI-compatible — just change the base URL.
# Examples:
#   Gemini:     https://generativelanguage.googleapis.com/v1beta/openai
#   ZhipuAI:   https://open.bigmodel.cn/api/paas/v4
#   Minimax:   https://api.minimax.chat/v1
#   DeepSeek:  https://api.deepseek.com/v1
#   Groq:      https://api.groq.com/openai/v1
LLM_BASE_URL=https://api.openai.com/v1

# Uniswap Trading API — real price feed plus quote/swap construction
# Get an API key at https://developers.uniswap.org/dashboard
UNISWAP_ENABLED=false
UNISWAP_API_KEY=
UNISWAP_BASE_URL=https://trade-api.gateway.uniswap.org/v1
UNISWAP_CHAIN_ID=1
# Placeholder address used for quote requests (no funds needed for price-only queries)
UNISWAP_SWAPPER_ADDRESS=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045
UNISWAP_TIMEOUT_MS=15000
UNISWAP_MAX_RETRIES=2

# KeeperHub Direct Execution API — reliable onchain execution for real mode
# Default demo target is Sepolia. Set UNISWAP_CHAIN_ID=11155111 for Sepolia quotes/swaps.
KEEPERHUB_ENABLED=false
KEEPERHUB_API_KEY=
KEEPERHUB_BASE_URL=https://app.keeperhub.com
KEEPERHUB_NETWORK=sepolia
KEEPERHUB_AUTH_MODE=bearer
KEEPERHUB_TIMEOUT_MS=20000
KEEPERHUB_POLL_INTERVAL_MS=2000
KEEPERHUB_POLL_TIMEOUT_MS=60000
KEEPERHUB_MAX_RETRIES=2
KEEPERHUB_GAS_LIMIT_MULTIPLIER=1.2
